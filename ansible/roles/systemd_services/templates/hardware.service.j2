[Unit]
Description=Magni hardware, drivers and teleop mux
After=network.target rmw_zenohd.service magni-uart-pinctrl.service
Wants=rmw_zenohd.service magni-uart-pinctrl.service

[Service]
Type=simple
User={{ target_user }}
Group={{ target_user }}
WorkingDirectory={{ ros2_ws }}
Environment=HOME={{ target_user_home }}
ExecStart=/usr/local/bin/magni-ros2-run.sh robot_bringup hardware.launch.py
Restart=on-failure
RestartSec=2
TimeoutStopSec=10

[Install]
WantedBy=multi-user.target
